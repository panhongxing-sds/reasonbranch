# Copy to repo-root .env or export before running API-dependent experiments.
# NEVER commit real keys.

# Teacher oracle (GreatRouter or OpenRouter)
TEACHER_API_KEY=
TEACHER_BASE_URL=https://openrouter.ai/api/v1
TEACHER_MODEL=openai/gpt-4.1

# Optional: path to key file (outside repo)
TEACHER_KEYFILE=/path/to/key/api

# HuggingFace mirror (cluster default)
HF_ENDPOINT=https://hf-mirror.com

# Model paths (cluster)
DRAFT_MODEL=/path/to/DeepSeek-R1-Distill-Qwen-1.5B
TARGET_MODEL=/path/to/DeepSeek-R1-Distill-Qwen-14B

# Workspace root (parent of reasoning_branch_dataset package)
AFS=/mnt/afs/L202500372
